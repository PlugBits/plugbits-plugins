      "app/plugin.js"
    ],
    "css": [
      "app/plugin.css"
    ]
  },
  "config": {
    "html": "config/config.html",
    "css": [
      "config/config.css"
    ],
    "js": [
      "config/config.js"
    ]
  }
}
