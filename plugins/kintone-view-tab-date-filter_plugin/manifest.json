{
  "manifest_version": 1,
  "version": "0.2.0",
  "type": "APP",
  "name": {
    "ja": "PlugBits ListKit",
    "en": "PlugBits ListKit"
  },
  "description": {
    "ja": "一覧のタブ切替・期間フィルター・集計をワンプラグインで。一覧画面の操作効率を一気に上げる。",
    "en": "Supercharge your kintone list views with tab navigation, one-click period filters, and real-time aggregation - all in one plugin."
  },
